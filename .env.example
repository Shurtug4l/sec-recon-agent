# External APIs
ANTHROPIC_API_KEY=
NVD_API_KEY=

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Service binding
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8001
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8000

# Storage
CHROMA_PERSIST_DIR=./data/cve_index

# Behavior
NVD_RATE_LIMIT_PER_30S=5
LOG_LEVEL=INFO
