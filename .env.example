# External APIs
ANTHROPIC_API_KEY=
NVD_API_KEY=
# Optional: enables GitHub Code Search for public PoC discovery in exploit_check.
# Without it the GitHub side gracefully degrades to []. Use a fine-grained PAT
# with public_repo read scope (no other scopes needed).
GITHUB_TOKEN=

# LLM
LLM_PROVIDER=anthropic
# Default: Haiku 4.5 — cheapest tier, sufficient for tool-calling + structured
# output. Override to claude-sonnet-4-6 for richer prose, or claude-opus-4-7
# for the strongest reasoning at ~10x the cost.
LLM_MODEL=claude-haiku-4-5-20251001

# Service binding
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8001
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8000

# Storage
CHROMA_PERSIST_DIR=./data/cve_index
# Local (non-Docker) default. In docker-compose the agent-api rootfs is
# read-only, so compose overrides this to /app/audit/audit.db on a dedicated
# writable volume; otherwise the audit trail cannot be written.
AUDIT_DB_PATH=./data/audit.db

# Audit trail (append-only SQLite with SHA-256 hash chain).
# AUDIT_LOG_ENABLED master switch: false disables persistence entirely.
# AUDIT_INCLUDE_QUERY / _SUMMARY: opt in to plain-text retention. Default
# off — only digests + aggregate counts are persisted, never the raw
# query or report summary.
AUDIT_LOG_ENABLED=true
AUDIT_INCLUDE_QUERY=false
AUDIT_INCLUDE_SUMMARY=false

# Authentication and rate limiting (API surface)
# API_KEYS: comma-separated list of accepted keys. Empty (default) leaves
# /v1/triage and /v1/meta open — fine for local dev, not for anything
# reachable beyond localhost. When set, every request must carry
# `Authorization: Bearer <key>` or `X-API-Key: <key>`. /v1/health stays
# public so container orchestrators can probe it.
API_KEYS=
# RATE_LIMIT_PER_MINUTE: per-IP cap on /v1/triage. 0 or unset disables.
# Set to 30-60 for a single-user demo; lower behind a real WAF.
RATE_LIMIT_PER_MINUTE=
# When API_KEYS is set, the Next.js proxy must forward one of those keys
# upstream. AGENT_API_KEY is read by the proxy only; never exposed to
# the browser.
AGENT_API_KEY=

# Authentication on the MCP transport (mcp-server, :8001).
# MCP_AUTH_TOKEN: shared bearer secret. Empty (default) leaves the MCP
# server open; safe only because docker-compose does NOT publish :8001
# to the host. Set whenever the port is reachable beyond the compose
# internal network. With the token set, every HTTP request to the MCP
# server must carry `Authorization: Bearer <token>`; comparison is
# constant-time.
MCP_AUTH_TOKEN=

# Behavior
# Hybrid retrieval for cve_semantic_search: dense MiniLM cosine fused
# (reciprocal-rank fusion) with an in-process BM25 over the same corpus.
# CVE text is identifier-heavy, which BM25 matches exactly and dense
# embeddings blur. false restores dense-only retrieval. The BM25 index is
# built lazily at first query and cached per process; after re-seeding,
# restart the MCP server to pick up the new corpus.
RETRIEVAL_HYBRID_ENABLED=true
NVD_RATE_LIMIT_PER_30S=5
# Max model requests (ReAct rounds) per triage before the agent is stopped
# with a clean error. Bounds a runaway loop; legitimate triages use far fewer.
AGENT_REQUEST_LIMIT=25
LOG_LEVEL=INFO

# Observability (OpenTelemetry)
# Leave empty for stdout span output (default). Set to an OTLP/HTTP endpoint
# to ship to a backend; the Jaeger compose profile exposes one at :4318.
# Example: http://jaeger:4318  (from inside docker compose)
# Example: http://localhost:4318  (from host shell hitting compose-published port)
OTEL_EXPORTER_OTLP_ENDPOINT=
