# Mirror .gitignore + things that should never enter the build context.

__pycache__/
*.py[cod]
*$py.class
*.so

.venv/
venv/
env/

build/
dist/
*.egg-info/
.eggs/

.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Secrets and runtime artefacts must NEVER ride in the build context.
.env
.env.local
data/

# Git plumbing not useful in the image.
.git/
.gitignore
.github/

# Editor / IDE
.DS_Store
.idea/
.vscode/

# Documentation that does not need to be in the image.
docs/
examples/
tests/
CLAUDE.md

# Docker artefacts referencing themselves.
Dockerfile
.dockerignore
docker-compose.yml
Makefile
